# Force no-cache on HTML pages so browsers and proxies never serve stale content
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# version.js must never be cached — it identifies the deployed build
<Files "version.js">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# Long cache for all other versioned assets (JS, CSS, images) — cache busting via ?v= param handles updates
<FilesMatch "\.(js|css|png|svg|jpg|jpeg|gif|ico|woff2?)$">
  Header set Cache-Control "public, max-age=31536000"
</FilesMatch>
