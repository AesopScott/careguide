rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPractitioner() {
      return isAuth() && userDoc().role == 'practitioner';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can read/write their own profile. Admins can read all profiles.

    match /users/{userId} {
      allow read:  if isAuth() && (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if isAuth() && (request.auth.uid == userId || request.auth.token.admin == true);
    }

    // ── Practitioners ─────────────────────────────────────────────────────────
    // Practitioners own their profile, session notes, and billing records.

    match /practitioners/{practitionerId} {
      allow read, write: if isAuth() && request.auth.uid == practitionerId;

      match /sessionNotes/{noteId} {
        allow read, write: if isAuth() && request.auth.uid == practitionerId;
      }

      match /billingRecords/{recordId} {
        allow read, write: if isAuth() && request.auth.uid == practitionerId;
      }
    }

    // ── Family Groups ─────────────────────────────────────────────────────────
    // Top-level family_groups doc. Practitioners own them; family members
    // belong via token.claims.family_group_id (set when the practitioner
    // invites them). Subcollections of family_groups are not used — related
    // data (parents, medications, etc.) lives in top-level collections keyed
    // by family_group_id.

    match /family_groups/{groupId} {
      allow read:   if isAuth() && (
                       request.auth.token.admin == true ||
                       resource.data.practitioner_id == request.auth.uid ||
                       request.auth.token.family_group_id == groupId
                     );
      allow create: if isPractitioner() &&
                       request.resource.data.practitioner_id == request.auth.uid;
      allow update: if isAuth() && (
                       request.auth.token.admin == true ||
                       resource.data.practitioner_id == request.auth.uid
                     );
      allow delete: if isAuth() && (
                       request.auth.token.admin == true ||
                       resource.data.practitioner_id == request.auth.uid
                     );
    }

    // ── Family-scoped collections (parents, medications) ─────────────────────
    // Top-level collections filtered by family_group_id. Access is granted to
    // the practitioner who owns the parent family_group, family members of
    // that group (via custom claim), and admins.

    function ownsGroup(groupId) {
      return get(/databases/$(database)/documents/family_groups/$(groupId)).data.practitioner_id == request.auth.uid;
    }

    function canAccessFamilyData(familyGroupId) {
      return isAuth() && (
        request.auth.token.admin == true ||
        request.auth.token.family_group_id == familyGroupId ||
        ownsGroup(familyGroupId)
      );
    }

    function canWriteFamilyData(familyGroupId) {
      return isAuth() && (
        request.auth.token.admin == true ||
        ownsGroup(familyGroupId)
      );
    }

    match /parents/{parentId} {
      allow read:                if canAccessFamilyData(resource.data.family_group_id);
      allow create:              if canWriteFamilyData(request.resource.data.family_group_id);
      allow update, delete:      if canWriteFamilyData(resource.data.family_group_id);
    }

    match /medications/{medId} {
      allow read:                if canAccessFamilyData(resource.data.family_group_id);
      allow create:              if canWriteFamilyData(request.resource.data.family_group_id);
      allow update, delete:      if canWriteFamilyData(resource.data.family_group_id);
    }

    // ── Waitlist ──────────────────────────────────────────────────────────────
    // Anyone can join; only admins can read the list.

    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'joinedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0;
      allow read, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ── AI Conversations ──────────────────────────────────────────────────────
    // Each user owns their own conversation history.

    match /aiConversations/{convId} {
      allow read, update, delete: if isAuth() &&
                                     resource.data.user_id == request.auth.uid;
      allow create: if isAuth() &&
                       request.resource.data.user_id == request.auth.uid;
    }
  }
}
