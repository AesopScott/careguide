rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPractitioner() {
      return isAuth() && userDoc().role == 'practitioner';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can read/write their own profile. Admins can read all profiles.

    match /users/{userId} {
      allow read:  if isAuth() && (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if isAuth() && (request.auth.uid == userId || request.auth.token.admin == true);
    }

    // ── Family Groups ─────────────────────────────────────────────────────────
    // Top-level family_groups doc. Practitioners own them; family members
    // belong via token.claims.family_group_ids (array; set by accept-invite).
    // Subcollections of family_groups are not used — related data (parents,
    // medications, etc.) lives in top-level collections keyed by
    // family_group_id field.

    function inFamilyGroups(groupId) {
      return request.auth.token.family_group_ids != null &&
             groupId in request.auth.token.family_group_ids;
    }

    match /family_groups/{groupId} {
      allow read:   if isAuth() && (
                       request.auth.token.admin == true ||
                       resource.data.practitioner_id == request.auth.uid ||
                       inFamilyGroups(groupId)
                     );
      allow create: if isPractitioner() &&
                       request.resource.data.practitioner_id == request.auth.uid;
      allow update: if isAuth() && (
                       request.auth.token.admin == true ||
                       resource.data.practitioner_id == request.auth.uid
                     );
      allow delete: if isAuth() && (
                       request.auth.token.admin == true ||
                       resource.data.practitioner_id == request.auth.uid
                     );
    }

    // ── Family-scoped collections (parents, medications) ─────────────────────
    // Top-level collections filtered by family_group_id. Access is granted to
    // the practitioner who owns the parent family_group, family members whose
    // family_group_ids claim includes the group, and admins.

    function ownsGroup(groupId) {
      return get(/databases/$(database)/documents/family_groups/$(groupId)).data.practitioner_id == request.auth.uid;
    }

    function canAccessFamilyData(familyGroupId) {
      return isAuth() && (
        request.auth.token.admin == true ||
        inFamilyGroups(familyGroupId) ||
        ownsGroup(familyGroupId)
      );
    }

    function canWriteFamilyData(familyGroupId) {
      return isAuth() && (
        request.auth.token.admin == true ||
        ownsGroup(familyGroupId)
      );
    }

    match /parents/{parentId} {
      allow read:                if canAccessFamilyData(resource.data.family_group_id);
      allow create:              if canWriteFamilyData(request.resource.data.family_group_id);
      allow update, delete:      if canWriteFamilyData(resource.data.family_group_id);
    }

    match /medications/{medId} {
      allow read:                if canAccessFamilyData(resource.data.family_group_id);
      allow create:              if canWriteFamilyData(request.resource.data.family_group_id);
      allow update, delete:      if canWriteFamilyData(resource.data.family_group_id);
    }

    match /session_notes/{noteId} {
      // Clinical notes — practitioner + admin only, no family read.
      allow read:                if isAuth() && (
                                    request.auth.token.admin == true ||
                                    ownsGroup(resource.data.family_group_id)
                                  );
      allow create:              if isAuth() && (
                                    request.auth.token.admin == true ||
                                    ownsGroup(request.resource.data.family_group_id)
                                  );
      allow update, delete:      if isAuth() && (
                                    request.auth.token.admin == true ||
                                    ownsGroup(resource.data.family_group_id)
                                  );
    }

    match /family_messages/{messageId} {
      // Family <-> practitioner messaging. Both can read/write within their group.
      allow read:                if canAccessFamilyData(resource.data.family_group_id);
      allow create:              if canAccessFamilyData(request.resource.data.family_group_id) &&
                                    request.resource.data.from_uid == request.auth.uid;
      allow update, delete:      if canAccessFamilyData(resource.data.family_group_id) &&
                                    (request.auth.token.admin == true ||
                                     resource.data.from_uid == request.auth.uid);
    }

    // ── Doc-id-equals-family_group_id collections ────────────────────────────
    // care_plans, intake_data, crisis_info are keyed by family_group_id as the
    // document id, so the rule can use {groupId} directly without reading
    // resource.data.

    match /care_plans/{groupId} {
      // Care plans — practitioner full access, family read, admin full access.
      allow read:                if canAccessFamilyData(groupId);
      allow write:               if canWriteFamilyData(groupId);
    }

    match /intake_data/{groupId} {
      // Intake form — practitioner-driven; family not granted access.
      allow read, write:         if isAuth() && (
                                    request.auth.token.admin == true ||
                                    ownsGroup(groupId)
                                  );
    }

    match /crisis_info/{groupId} {
      // Crisis card — practitioner full access, family read (emergency).
      allow read:                if canAccessFamilyData(groupId);
      allow write:               if canWriteFamilyData(groupId);
    }

    // ── Family invitations and care updates ──────────────────────────────────

    match /family_invitations/{invitationId} {
      // Pending invitations from practitioner to a family-member email.
      // The accept-invite endpoint uses Admin SDK so it bypasses these rules.
      // Practitioners can manage invites for groups they own; admin can manage any.
      // Family members never read or write these directly.
      allow read:                if isAuth() && (
                                    request.auth.token.admin == true ||
                                    ownsGroup(resource.data.family_group_id)
                                  );
      allow create:              if isAuth() && (
                                    request.auth.token.admin == true ||
                                    ownsGroup(request.resource.data.family_group_id)
                                  );
      allow update, delete:      if isAuth() && (
                                    request.auth.token.admin == true ||
                                    ownsGroup(resource.data.family_group_id)
                                  );
    }

    match /care_updates/{updateId} {
      // Practitioner posts; family in that group can read.
      allow read:                if canAccessFamilyData(resource.data.family_group_id);
      allow create:              if canWriteFamilyData(request.resource.data.family_group_id) &&
                                    request.resource.data.author_uid == request.auth.uid;
      allow update, delete:      if canWriteFamilyData(resource.data.family_group_id);
    }

    // ── Waitlist ──────────────────────────────────────────────────────────────
    // Anyone can join; only admins can read the list.

    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'joinedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0;
      allow read, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ── AI Conversations ──────────────────────────────────────────────────────
    // Each user owns their own conversation history.

    match /aiConversations/{convId} {
      allow read, update, delete: if isAuth() &&
                                     resource.data.user_id == request.auth.uid;
      allow create: if isAuth() &&
                       request.resource.data.user_id == request.auth.uid;
    }
  }
}
